RewriteEngine On



# XAMPP subdirectory — use RewriteBase / on live when the site is at domain root

RewriteBase /api_integration/allenhouseghaziabad/



RewriteCond %{HTTP_HOST} localhost [NC,OR]

RewriteCond %{HTTP_HOST} \.local$ [NC,OR]

RewriteCond %{HTTP_HOST} ^127\.0\.0\.1$

RewriteRule ^ - [E=APS_LOCAL:1]



RewriteCond %{ENV:APS_LOCAL} !=1

RewriteCond %{HTTPS} !=on

RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]



<IfModule mod_headers.c>

    SetEnvIf Request_URI "(?i)\.(?:css|js|mjs|ico|jpg|jpeg|png|gif|webp|svg|woff2?|ttf|eot|map)$" STATIC_ASSET

    Header set Cache-Control "public, max-age=2592000" env=STATIC_ASSET

    Header set Cache-Control "private, no-cache, must-revalidate" env=!STATIC_ASSET

</IfModule>



DirectoryIndex index.php



# Serve existing files and directories directly

RewriteCond %{REQUEST_FILENAME} -f [OR]

RewriteCond %{REQUEST_FILENAME} -d

RewriteRule ^ - [L]



# Fix mistaken double /blog/blog/slug links (from old relative URLs on /blog page)

RewriteRule ^blog/blog/([A-Za-z0-9_-]+)/?$ blog/$1 [NC,R=301,L]



# Pretty URLs

RewriteRule ^home/?$ index.php [NC,L]

RewriteRule ^blog/([A-Za-z0-9_-]+)/?$ detail.php?slug=$1 [NC,L,QSA]

RewriteRule ^view/([A-Za-z0-9_-]+)/?$ detail-view.php?slug=$1 [NC,L,QSA]



# Map clean URLs to matching .php files (e.g. /blog -> blog.php)

RewriteCond %{REQUEST_FILENAME}.php -f

RewriteRule ^(.+?)/?$ $1.php [L]



# CMS dynamic page when no local PHP file exists

RewriteCond %{REQUEST_FILENAME}.php !-f

RewriteRule ^([A-Za-z0-9_-]+)/?$ cms-page.php?cms_path=$1 [NC,L,QSA]



# Fallback

RewriteRule ^ index.php [L]



ErrorDocument 404 /api_integration/allenhouseghaziabad/index.php

ErrorDocument 500 /api_integration/allenhouseghaziabad/index.php

